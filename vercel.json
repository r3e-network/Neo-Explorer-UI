{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/mainnet/primary",
      "dest": "https://neofura.ngd.network"
    },
    {
      "src": "/api/mainnet/fallback",
      "dest": "https://neofura.ngd.network"
    },
    {
      "src": "/api/testnet/primary",
      "dest": "https://testmagnet.ngd.network"
    },
    {
      "src": "/api/testnet/fallback",
      "dest": "https://testmagnet.ngd.network"
    },
    {
      "src": "/api/mainnet",
      "dest": "https://neofura.ngd.network"
    },
    {
      "src": "/api/testnet",
      "dest": "https://testmagnet.ngd.network"
    },
    {
      "src": "/api",
      "dest": "/api/mainnet"
    },
    {
      "src": "/bpi/mainnet/(.*)",
      "dest": "https://neofura.ngd.network/bpi/$1"
    },
    {
      "src": "/bpi/testnet/(.*)",
      "dest": "https://testmagnet.ngd.network/bpi/$1"
    },
    {
      "src": "/bpi/(.*)",
      "dest": "/bpi/mainnet/$1"
    },
    {
      "src": "/neotube-api/(.*)",
      "dest": "https://api.neotube.io/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}