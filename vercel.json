{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/sync_mempool",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/check_alerts",
      "schedule": "*/1 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/mainnet/primary",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/api/mainnet/fallback",
      "destination": "https://api1.n3index.dev/mainnet"
    },
    {
      "source": "/api/mainnet/fallback2",
      "destination": "https://api2.n3index.dev/mainnet"
    },
    {
      "source": "/api/mainnet/fallback3",
      "destination": "https://api3.n3index.dev/mainnet"
    },
    {
      "source": "/api/testnet/primary",
      "destination": "https://api.n3index.dev/testnet"
    },
    {
      "source": "/api/testnet/fallback",
      "destination": "https://api1.n3index.dev/testnet"
    },
    {
      "source": "/api/testnet/fallback2",
      "destination": "https://api2.n3index.dev/testnet"
    },
    {
      "source": "/api/testnet/fallback3",
      "destination": "https://api3.n3index.dev/testnet"
    },
    {
      "source": "/api/mainnet",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/api/testnet",
      "destination": "https://api.n3index.dev/testnet"
    },
    {
      "source": "/api",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/bpi/mainnet/(.*)",
      "destination": "https://rpc.r3e.network/mainnet/bpi/$1"
    },
    {
      "source": "/bpi/testnet/(.*)",
      "destination": "https://rpc.r3e.network/testnet/bpi/$1"
    },
    {
      "source": "/bpi/(.*)",
      "destination": "https://rpc.r3e.network/mainnet/bpi/$1"
    },
    {
      "source": "/indexer/mainnet/(.*)",
      "destination": "https://api.n3index.dev/indexer/v1/networks/mainnet/$1"
    },
    {
      "source": "/indexer/testnet/(.*)",
      "destination": "https://api.n3index.dev/indexer/v1/networks/testnet/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}
