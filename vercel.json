{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/sync_mempool",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/check_alerts",
      "schedule": "*/1 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/rpc/:network/:endpoint*",
      "destination": "https://api.n3index.dev/:network"
    },
    {
      "source": "/api/:network/:endpoint*",
      "destination": "https://api.n3index.dev/:network"
    },
    {
      "source": "/api",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/data/:network/:rest*",
      "destination": "https://api.n3index.dev/:network/:rest*"
    },
    {
      "source": "/indexer/:network/:rest*",
      "destination": "https://api.n3index.dev/:network/:rest*"
    },
    {
      "source": "/rest/:network/(.*)",
      "destination": "https://api.n3index.dev/rest/v1/$1"
    },
    {
      "source": "/:path((?!api/|rpc/|bpi/|indexer/|data/|assets/|img/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path((?!assets/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
