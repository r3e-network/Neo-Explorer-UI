{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "devCommand": "npm run dev -- --host 127.0.0.1 --port $PORT",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/sync_mempool",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/check_alerts",
      "schedule": "*/1 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/api",
      "destination": "/api-docs",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/rpc/mainnet/primary",
      "destination": "https://rpc.n3index.dev/mainnet"
    },
    {
      "source": "/rpc/mainnet/fallback",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/rpc/mainnet/fallback2",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/rpc/mainnet/fallback3",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/rpc/testnet/primary",
      "destination": "https://testnet1.neo.coz.io"
    },
    {
      "source": "/rpc/testnet/fallback",
      "destination": "https://api.n3index.dev/testnet"
    },
    {
      "source": "/rpc/testnet/fallback2",
      "destination": "https://api.n3index.dev/testnet"
    },
    {
      "source": "/rpc/testnet/fallback3",
      "destination": "https://api.n3index.dev/testnet"
    },
    {
      "source": "/rpc/mainnet",
      "destination": "https://rpc.n3index.dev/mainnet"
    },
    {
      "source": "/rpc/testnet",
      "destination": "https://testnet1.neo.coz.io"
    },
    {
      "source": "/api/mainnet/primary",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/api/mainnet/fallback",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/api/mainnet/fallback2",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/api/mainnet/fallback3",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/api/testnet/primary",
      "destination": "https://api.n3index.dev/testnet"
    },
    {
      "source": "/api/testnet/fallback",
      "destination": "https://api.n3index.dev/testnet"
    },
    {
      "source": "/api/testnet/fallback2",
      "destination": "https://api.n3index.dev/testnet"
    },
    {
      "source": "/api/testnet/fallback3",
      "destination": "https://api.n3index.dev/testnet"
    },
    {
      "source": "/api/mainnet",
      "destination": "https://api.n3index.dev/mainnet"
    },
    {
      "source": "/api/testnet",
      "destination": "https://api.n3index.dev/testnet"
    },
    {
      "source": "/data/mainnet/fallback/(.*)",
      "destination": "https://api.n3index.dev/mainnet/$1"
    },
    {
      "source": "/data/mainnet/fallback2/(.*)",
      "destination": "https://api.n3index.dev/mainnet/$1"
    },
    {
      "source": "/data/mainnet/fallback3/(.*)",
      "destination": "https://api.n3index.dev/mainnet/$1"
    },
    {
      "source": "/data/mainnet/(.*)",
      "destination": "https://api.n3index.dev/mainnet/$1"
    },
    {
      "source": "/data/testnet/fallback/(.*)",
      "destination": "https://api.n3index.dev/testnet/$1"
    },
    {
      "source": "/data/testnet/fallback2/(.*)",
      "destination": "https://api.n3index.dev/testnet/$1"
    },
    {
      "source": "/data/testnet/fallback3/(.*)",
      "destination": "https://api.n3index.dev/testnet/$1"
    },
    {
      "source": "/data/testnet/(.*)",
      "destination": "https://api.n3index.dev/testnet/$1"
    },
    {
      "source": "/indexer/mainnet/fallback/(.*)",
      "destination": "https://api.n3index.dev/mainnet/$1"
    },
    {
      "source": "/indexer/mainnet/fallback2/(.*)",
      "destination": "https://api.n3index.dev/mainnet/$1"
    },
    {
      "source": "/indexer/mainnet/fallback3/(.*)",
      "destination": "https://api.n3index.dev/mainnet/$1"
    },
    {
      "source": "/indexer/mainnet/(.*)",
      "destination": "https://api.n3index.dev/mainnet/$1"
    },
    {
      "source": "/indexer/testnet/fallback/(.*)",
      "destination": "https://api.n3index.dev/testnet/$1"
    },
    {
      "source": "/indexer/testnet/fallback2/(.*)",
      "destination": "https://api.n3index.dev/testnet/$1"
    },
    {
      "source": "/indexer/testnet/fallback3/(.*)",
      "destination": "https://api.n3index.dev/testnet/$1"
    },
    {
      "source": "/indexer/testnet/(.*)",
      "destination": "https://api.n3index.dev/testnet/$1"
    },
    {
      "source": "/rest/mainnet/(.*)",
      "destination": "https://api.n3index.dev/rest/v1/$1"
    },
    {
      "source": "/rest/testnet/(.*)",
      "destination": "https://api.n3index.dev/rest/v1/$1"
    },
    {
      "source": "/neox/:net/:path*",
      "destination": "/api/neox"
    },
    {
      "source": "/neox-stats/:net/:path*",
      "destination": "/api/neox-stats"
    },
    {
      "source": "/neox-rpc/:net",
      "destination": "/api/neox-rpc/:net"
    },
    {
      "source": "/x",
      "destination": "/x.html"
    },
    {
      "source": "/x/:path*",
      "destination": "/x.html"
    },
    {
      "source": "/:path((?!api/|rpc/|bpi/|indexer/|data/|neox/|neox-stats/|neox-rpc/|assets/|img/|@vite/|@id/|@fs/|src/|node_modules/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path((?!assets/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' 'wasm-unsafe-eval' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: wss:; frame-src https:; worker-src 'self' blob:; manifest-src 'self'; form-action 'self'"
        }
      ]
    }
  ]
}
