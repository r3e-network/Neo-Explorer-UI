# No required env vars for default setup.
#
# Optional RPC override:
# - Generic custom URL stays fixed and bypasses the UI network switch
#   VITE_RPC_BASE_URL=https://your-rpc-proxy.example/api
# - URL ending in /api/mainnet or /api/testnet stays network-aware
#   VITE_RPC_BASE_URL=https://your-rpc-proxy.example/api/mainnet
#
# Optional per-network Vite dev proxy targets:
# VITE_MAINNET_RPC_PROXY_TARGET=https://neofura.ngd.network
# VITE_TESTNET_RPC_PROXY_TARGET=https://testmagnet.ngd.network
# VITE_MAINNET_BPI_PROXY_TARGET=https://neofura.ngd.network
# VITE_TESTNET_BPI_PROXY_TARGET=https://testmagnet.ngd.network
# Optional indexer proxy target (defaults to Cloudflare worker):
# VITE_INDEXER_PROXY_TARGET=https://api.n3index.dev
# Optional legacy read API origin and abstract-account contract hashes:
# VITE_SUPABASE_URL=https://api.n3index.dev
# VITE_AA_HASH_MAINNET=0x...
# VITE_AA_HASH_TESTNET=0x...

# Optional WalletConnect / Neon Wallet support:
# VITE_WC_PROJECT_ID=your_walletconnect_project_id

# Optional Sentry browser + serverless API telemetry:
# VITE_SENTRY_DSN=https://public@example.ingest.sentry.io/123
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.0
# VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
# SENTRY_DSN=https://public@example.ingest.sentry.io/123
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.0

# Optional PostHog product analytics / replay / feature flags:
# VITE_POSTHOG_KEY=phc_your_project_key
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_POSTHOG_CAPTURE_DEV=false
# VITE_APP_RELEASE=$VERCEL_GIT_COMMIT_SHA

# Optional serverless API Sentry release tag:
# SENTRY_RELEASE=$VERCEL_GIT_COMMIT_SHA

# Optional shared serverless rate limiting (recommended in production):
# UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
# DATABASE_URL=postgres://user:password@host/database?sslmode=require
# Shared rate limiting prefers Upstash and uses DATABASE_URL/POSTGRES_URL as a distributed fallback.
# ADDRESS_RADAR_PATH_RATE_LIMIT_PER_MINUTE=24
# ADDRESS_RADAR_DIRECT_RATE_LIMIT_PER_MINUTE=90
# ADDRESS_RADAR_RATE_LIMIT_DISABLE_SHARED=0
# ADDRESS_RADAR_RATE_LIMIT_FAIL_OPEN=0

# Required for the internal NeoChat server-side API:
# CHAT_DATABASE_URL=postgres://postgres:password@db.<project>.supabase.co:5432/postgres?sslmode=require
# CHAT_SESSION_SECRET=replace_with_a_long_random_secret

# --- AI assistant (/api/agent) ---
# The assistant is non-custodial and scope-locked to Neo N3 / Neo X topics.
# Without DEEPSEEK_API_KEY the endpoint degrades to 503 agent_unconfigured;
# without NEOX_MCP_URL it degrades to 503 mcp_unconfigured. Both are required
# for the assistant to answer.
# DEEPSEEK_API_KEY=sk-your_deepseek_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# AGENT_MODEL=deepseek-v4-flash
# AGENT_RATE_LIMIT_PER_MINUTE=20

# Remote neo-n3-mcp server (MCP Streamable HTTP transport).
# Run it with `npm run start:mcp-http` in the neo-n3-mcp repo; see that repo's
# docs/remote-mcp-transport.md. Must be HTTPS in production.
# NEOX_MCP_URL=http://127.0.0.1:3001/mcp
# NEOX_MCP_BEARER=replace_with_a_long_random_secret
