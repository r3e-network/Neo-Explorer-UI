# No required env vars for default setup.
#
# Optional fixed override (bypasses UI network switch):
# VITE_RPC_BASE_URL=https://your-rpc-proxy.example/api
#
# Optional per-network Vite dev proxy targets:
# VITE_MAINNET_RPC_PROXY_TARGET=https://neofura.ngd.network
# VITE_TESTNET_RPC_PROXY_TARGET=https://testmagnet.ngd.network
# VITE_MAINNET_BPI_PROXY_TARGET=https://neofura.ngd.network
# VITE_TESTNET_BPI_PROXY_TARGET=https://testmagnet.ngd.network
