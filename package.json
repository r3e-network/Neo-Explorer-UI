{
  "name": "neo-explorer",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/sync-abstract-account-artifacts.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .js,.jsx,.vue src tests",
    "lint-fix": "eslint --fix --ext .js --ext .jsx --ext .vue src/",
    "validate:rpc": "node scripts/validate-rpc-consistency.mjs",
    "validate:rpc:strict": "FAIL_ON_FRONTEND_DOC_GAPS=1 FAIL_ON_BACKEND_UNDOCUMENTED=1 node scripts/validate-rpc-consistency.mjs",
    "validate:rpc:sync-docs": "WRITE_MISSING_BACKEND_DOCS=1 REFRESH_AUTOGENERATED_BACKEND_DOCS=1 node scripts/validate-rpc-consistency.mjs",
    "qa": "npm run lint && npm test && npm run build",
    "qa:full": "npm run lint && npm test && npm run validate:rpc && npm run build",
    "sync:abstract-account-artifacts": "node scripts/sync-abstract-account-artifacts.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cityofzion/neon-dappkit": "^1.0.0",
    "@cityofzion/neon-js": "^5.8.0",
    "@highlightjs/vue-plugin": "^2.1.0",
    "@supabase/supabase-js": "^2.97.0",
    "@vercel/edge-config": "^1.4.3",
    "@vueuse/core": "^14.2.1",
    "@walletconnect/sign-client": "^2.23.6",
    "@web3auth/base": "^9.7.0",
    "@web3auth/base-provider": "^9.7.0",
    "@web3auth/ethereum-provider": "^9.7.0",
    "@web3auth/modal": "^9.7.0",
    "axios": "^1.13.5",
    "bignumber.js": "^9.3.1",
    "bs58": "^6.0.0",
    "chart.js": "2.9.4",
    "core-js": "^3.29.1",
    "crypto-js": "^4.2.0",
    "ethereum-cryptography": "^3.2.0",
    "ethers": "^6.16.0",
    "highlight.js": "^11.11.1",
    "js-sha256": "^0.11.1",
    "pg": "^8.18.0",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0",
    "qrcode.vue": "^3.8.0",
    "sharp": "^0.34.5",
    "timeago.js": "^4.0.2",
    "vue": "^3.5.27",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/compiler-sfc": "^3.5.27",
    "@vue/eslint-config-prettier": "6.0.0",
    "@vue/test-utils": "^2.0.0-rc.18",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.1.2",
    "echarts": "^5.1.2",
    "eslint": "^8.57.1",
    "eslint-plugin-prettier": "3.3.1",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "prettier": "2.2.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "18.x || 20.x"
  }
}
