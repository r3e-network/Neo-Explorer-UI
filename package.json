{
  "name": "neo-explorer",
  "version": "1.3.0",
  "private": true,
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/sync-abstract-account-artifacts.mjs",
    "build": "vite build",
    "postbuild": "node scripts/copy-decompiler-web-assets.mjs && node scripts/generate-route-shells.mjs",
    "preview": "vite preview",
    "lint": "eslint --ext .js,.jsx,.vue src tests",
    "lint-fix": "eslint --fix --ext .js,.jsx,.vue src tests",
    "validate:rpc": "node scripts/validate-rpc-consistency.mjs",
    "validate:rpc:ci": "FAIL_ON_FRONTEND_DOC_GAPS=1 FAIL_ON_BACKEND_UNDOCUMENTED=0 node scripts/validate-rpc-consistency.mjs",
    "validate:governance:lab": "node scripts/governance-testnet-lower-threshold.js",
    "validate:governance:mock-policy": "node scripts/governance-testnet-mock-policy-lab.js",
    "validate:rpc:strict": "FAIL_ON_FRONTEND_DOC_GAPS=1 FAIL_ON_BACKEND_UNDOCUMENTED=1 node scripts/validate-rpc-consistency.mjs",
    "validate:rpc:sync-docs": "WRITE_MISSING_BACKEND_DOCS=1 REFRESH_AUTOGENERATED_BACKEND_DOCS=1 node scripts/validate-rpc-consistency.mjs",
    "qa": "npm run lint && npm test && npm run build",
    "qa:full": "npm run lint && npm test && npm run validate:rpc && npm run build",
    "audit:render": "node tests/browser-render-audit.mjs",
    "validate:postdeploy": "node scripts/post-deploy-cache-check.mjs && node tests/pages.test.js && CAPTURE_SCREENSHOTS=failures node tests/browser-render-audit.mjs",
    "sync:abstract-account-artifacts": "node scripts/sync-abstract-account-artifacts.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:high": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "@cityofzion/neon-js": "^5.8.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@r3e/neo-js-sdk": "^0.3.6",
    "@sentry/node": "^10.45.0",
    "@sentry/vue": "^10.45.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/vue-query": "^5.101.0",
    "@vercel/edge-config": "^1.4.3",
    "@vueuse/core": "^14.2.1",
    "@walletconnect/sign-client": "^2.23.6",
    "@web3auth/auth": "^11.8.1",
    "axios": "^1.13.5",
    "bs58": "^6.0.0",
    "chart.js": "2.9.4",
    "ethereum-cryptography": "^3.2.0",
    "ethers": "^6.16.0",
    "highlight.js": "^11.11.1",
    "highlightjs-solidity": "^2.0.6",
    "jszip": "^3.10.1",
    "neo-decompiler-web": "^0.11.0",
    "pg": "^8.20.0",
    "posthog-js": "^1.363.5",
    "qrcode.vue": "^3.8.0",
    "sharp": "^0.34.5",
    "vue": "^3.5.27",
    "vue-i18n": "^11.4.7",
    "vue-router": "^4.6.4",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/compiler-sfc": "^3.5.27",
    "@vue/test-utils": "^2.0.0-rc.18",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.0.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.5",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.1"
  },
  "engines": {
    "node": "22.x"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "lodash": "4.18.1",
    "ws": "8.21.0"
  }
}
